# ─────────────────────────────────────────────────────────────────────────────
# data-core — VPS Cloud Environment
# Copiar para /opt/data-core/.env e preencher todos os <PLACEHOLDER>
# chmod 600 /opt/data-core/.env
# ─────────────────────────────────────────────────────────────────────────────

APP_NAME=data-core
APP_ENV=production
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
LOG_JSON=true

# ── Banco (Neon — schema data_core) ─────────────────────────────────────────
# Neon → Project → Connection string → Python (pooled endpoint)
# ⚠️ CREDENCIAL ROTACIONADA em 2026-05-29 — obter nova senha no painel Neon
DATABASE_URL=postgresql+psycopg://neondb_owner:<ROTATE_VIA_NEON_DASHBOARD>@ep-quiet-rice-acd1l6ai-pooler.sa-east-1.aws.neon.tech/data_core?sslmode=require&channel_binding=require

# ── Redis (Railway Redis ou Redis Cloud) ─────────────────────────────────────
REDIS_URL=rediss://default:<TOKEN>@<HOST>:6380/0

# ── Segurança API ─────────────────────────────────────────────────────────────
API_KEY_ENABLED=true
# Gerar: openssl rand -hex 32
API_KEY=<GERAR_COM_openssl_rand_-hex_32>

# ── Scheduler ────────────────────────────────────────────────────────────────
SCHEDULER_ENABLED=true
SCHEDULER_COLLECTORS_ENABLED=true
SCHEDULER_PIPELINE_ENABLED=true
SCHEDULER_DOMAIN_JOBS_ENABLED=true
SCHEDULER_TIMEZONE=America/Sao_Paulo
WORKER_PIPELINE_INTERVAL_SECONDS=60

# ── Integrações ───────────────────────────────────────────────────────────────
# URL pública da Crypto API no mesmo VPS (acesso interno via loopback)
POUPI_CRYPTO_INTERNAL_URL=http://localhost:8002
CRYPTO_API_KEY=<GERAR_COM_openssl_rand_-hex_32>

# ── Telegram ─────────────────────────────────────────────────────────────────
TELEGRAM_ENABLED=true
TELEGRAM_BOT_TOKEN=<BOT_TOKEN>
TELEGRAM_CHAT_ID=<CHAT_ID>
TELEGRAM_SUMMARY_ENABLED=true
TELEGRAM_SUMMARY_OPERATIONAL_ENABLED=true
TELEGRAM_SUMMARY_QUANT_ENABLED=true

# ── Observabilidade ──────────────────────────────────────────────────────────
SENTRY_DSN=<SENTRY_DSN_DATA_CORE>

# ── Storage (datasets locais) ────────────────────────────────────────────────
STORAGE_URL=sqlite:////opt/data-core/runtime-data/crypto_coin.sqlite3
AUTO_CREATE_TABLES=false

# ── Collectors ────────────────────────────────────────────────────────────────
COLLECTOR_DEFAULT_MAX_RETRIES=3
COLLECTOR_DEFAULT_RETRY_DELAY_SECONDS=10
SYMBOLS=BTC/USDT,ETH/USDT,SOL/USDT,BNB/USDT,ADA/USDT,DOGE/USDT,XRP/USDT
TIMEFRAMES=15m,1h
