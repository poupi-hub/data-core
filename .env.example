APP_NAME=data-core
APP_ENV=development
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
LOG_JSON=false

DATABASE_URL=postgresql+psycopg://data_core:data_core@postgres:5432/data_core
AUTO_CREATE_TABLES=false

SCHEDULER_ENABLED=true
SCHEDULER_COLLECTORS_ENABLED=true
SCHEDULER_PIPELINE_ENABLED=true
SCHEDULER_DOMAIN_JOBS_ENABLED=true
SCHEDULER_TIMEZONE=America/Sao_Paulo
WORKER_CONCURRENCY=2
WORKER_PIPELINE_INTERVAL_SECONDS=300
COLLECTOR_DEFAULT_MAX_RETRIES=3
COLLECTOR_DEFAULT_RETRY_DELAY_SECONDS=10

# Auth — API key protection for all /api/* routes.
# In production: set API_KEY_ENABLED=true and generate a strong key:
#   python -c "import secrets; print(secrets.token_hex(32))"
# Exempt routes (no key required): /health, /metrics, /docs, /openapi.json
API_KEY_ENABLED=false
API_KEY=

# Redis cache — set CACHE_ENABLED=true when Redis is available
REDIS_URL=redis://redis:6379/0
CACHE_ENABLED=false

# Alerting — POST to this URL when operational alerts are detected (leave empty to disable)
# Supports any webhook receiver: Slack incoming webhook, Discord, n8n, etc.
ALERT_WEBHOOK_URL=
ALERT_WEBHOOK_RAW_FRESHNESS_HOURS=24
ALERT_WEBHOOK_RAW_PENDING_MINUTES=60
ALERT_WEBHOOK_ANALYTICS_PENDING_MINUTES=120

# Poupi legacy TS scraper bridge.
# Absolute path to the poupi-baby/backend directory (where raw-bridge.ts lives).
# In Docker: mount the poupi-baby/backend folder and set this to the mount path.
# Locally: leave unset — collector auto-detects ../poupi-baby/backend (sibling repo).
POUPI_LEGACY_BACKEND_DIR=/app/poupi-baby/backend

# Crypto Coin domain
EXCHANGE=binance
SYMBOL=BTC/USDT
TIMEFRAME=15m
PAPER_TRADING=true
PAPER_INITIAL_BALANCE=10000
STORAGE_URL=sqlite:///runtime-data/crypto_coin.sqlite3
CRYPTO_API_KEY=
CRYPTO_API_SECRET=
CRYPTO_API_PASSPHRASE=
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
