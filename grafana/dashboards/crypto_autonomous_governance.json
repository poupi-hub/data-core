{
  "uid": "crypto-autonomous-governance-o",
  "title": "Autonomous Quant Governance — Phase O",
  "description": "Fully Autonomous Governance & Self-Adaptive Execution Intelligence (Phase O)",
  "tags": ["crypto", "quant", "governance", "phase-o", "autonomous"],
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "timezone": "browser",
  "panels": [

    {
      "id": 1,
      "title": "Governance Health",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "min": 0, "max": 100,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": 0 },
            { "color": "orange", "value": 40 },
            { "color": "yellow", "value": 60 },
            { "color": "green", "value": 80 }
          ]}
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none", "textMode": "value_and_name" },
      "targets": [
        { "expr": "market_survival_score", "legendFormat": "Market Survival" },
        { "expr": "100 - systemic_risk_score", "legendFormat": "Systemic Health" }
      ]
    },

    {
      "id": 2,
      "title": "Market Survival Score",
      "type": "gauge",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "unit": "none", "min": 0, "max": 100,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": 0 },
            { "color": "orange", "value": 40 },
            { "color": "yellow", "value": 70 },
            { "color": "green", "value": 85 }
          ]}
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "showThresholdLabels": true },
      "targets": [{ "expr": "market_survival_score", "legendFormat": "Market Survival" }]
    },

    {
      "id": 3,
      "title": "Systemic Risk Score",
      "type": "gauge",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "unit": "none", "min": 0, "max": 100,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": 0 },
            { "color": "yellow", "value": 30 },
            { "color": "orange", "value": 60 },
            { "color": "red", "value": 80 }
          ]}
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "showThresholdLabels": true },
      "targets": [{ "expr": "systemic_risk_score", "legendFormat": "Systemic Risk" }]
    },

    {
      "id": 4,
      "title": "Self-Healing Score",
      "type": "gauge",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "unit": "none", "min": 0, "max": 100,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": 0 },
            { "color": "orange", "value": 40 },
            { "color": "green", "value": 70 }
          ]}
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "self_healing_score", "legendFormat": "Self-Healing" }]
    },

    {
      "id": 5,
      "title": "Adaptive Risk Score",
      "type": "gauge",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "unit": "none", "min": 0, "max": 100,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": 0 },
            { "color": "yellow", "value": 40 },
            { "color": "orange", "value": 65 },
            { "color": "red", "value": 80 }
          ]}
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "adaptive_risk_score", "legendFormat": "Adaptive Risk" }]
    },

    {
      "id": 6,
      "title": "Portfolio Survival Score",
      "type": "gauge",
      "gridPos": { "x": 20, "y": 0, "w": 4, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "unit": "none", "min": 0, "max": 100,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": 0 },
            { "color": "orange", "value": 40 },
            { "color": "green", "value": 70 }
          ]}
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "portfolio_survival_score", "legendFormat": "Portfolio Survival" }]
    },

    {
      "id": 10,
      "title": "Market Survival & Systemic Risk — Timeline",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 7 },
      "fieldConfig": {
        "defaults": { "unit": "none", "min": 0, "max": 100 },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Systemic Risk" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Market Survival" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] }
        ]
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        { "expr": "market_survival_score", "legendFormat": "Market Survival" },
        { "expr": "systemic_risk_score", "legendFormat": "Systemic Risk" },
        { "expr": "market_drift_score", "legendFormat": "Market Drift" }
      ]
    },

    {
      "id": 11,
      "title": "Adaptive Risk Components — Timeline",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 7 },
      "fieldConfig": {
        "defaults": { "unit": "none", "min": 0, "max": 100 }
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        { "expr": "adaptive_risk_score", "legendFormat": "Adaptive Risk" },
        { "expr": "self_healing_score", "legendFormat": "Self-Healing" },
        { "expr": "portfolio_survival_score", "legendFormat": "Portfolio Survival" },
        { "expr": "adaptive_efficiency_score", "legendFormat": "Adaptive Efficiency" }
      ]
    },

    {
      "id": 20,
      "title": "Strategy Trust Scores",
      "type": "bargauge",
      "gridPos": { "x": 0, "y": 11, "w": 12, "h": 6 },
      "fieldConfig": {
        "defaults": {
          "unit": "none", "min": 0, "max": 100,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": 0 },
            { "color": "orange", "value": 40 },
            { "color": "green", "value": 70 }
          ]}
        }
      },
      "options": { "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"] }, "displayMode": "gradient" },
      "targets": [{ "expr": "strategy_trust_score", "legendFormat": "{{strategy_id}}" }]
    },

    {
      "id": 21,
      "title": "Autonomous Strategy Switches — Rate",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 11, "w": 12, "h": 6 },
      "fieldConfig": {
        "defaults": { "unit": "ops" }
      },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "rate(autonomous_strategy_switch_total[5m])", "legendFormat": "{{strategy_id}} {{from_state}}→{{to_state}}" }
      ]
    },

    {
      "id": 30,
      "title": "Adaptive Exposure & Adaptive Efficiency",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 17, "w": 12, "h": 7 },
      "fieldConfig": {
        "defaults": { "unit": "none", "min": 0, "max": 100 }
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        { "expr": "adaptive_exposure_score", "legendFormat": "Adaptive Exposure" },
        { "expr": "adaptive_efficiency_score", "legendFormat": "Adaptive Efficiency" },
        { "expr": "parameter_stability_score", "legendFormat": "Parameter Stability" }
      ]
    },

    {
      "id": 31,
      "title": "Autonomous Execution Cycles — Rate",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 17, "w": 12, "h": 7 },
      "fieldConfig": {
        "defaults": { "unit": "ops" }
      },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "rate(autonomous_execution_total[5m])", "legendFormat": "{{type}}" }
      ]
    },

    {
      "id": 40,
      "title": "Portfolio Governance — Resilience & Health",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 24, "w": 12, "h": 7 },
      "fieldConfig": {
        "defaults": { "unit": "none", "min": 0, "max": 100 }
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        { "expr": "portfolio_resilience_score", "legendFormat": "Portfolio Resilience" },
        { "expr": "portfolio_survival_score", "legendFormat": "Portfolio Survival" },
        { "expr": "portfolio_health_score", "legendFormat": "Portfolio Health" },
        { "expr": "portfolio_correlation_avg", "legendFormat": "Avg Correlation" }
      ]
    },

    {
      "id": 41,
      "title": "Strategy Lifecycle — Degradation & Trust",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 24, "w": 12, "h": 7 },
      "fieldConfig": {
        "defaults": { "unit": "none", "min": 0, "max": 100 }
      },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "strategy_health_score", "legendFormat": "Health {{strategy_id}}" },
        { "expr": "strategy_degradation_score", "legendFormat": "Degradation {{strategy_id}}" },
        { "expr": "strategy_trust_score", "legendFormat": "Trust {{strategy_id}}" }
      ]
    },

    {
      "id": 50,
      "title": "Research Loop & Optimization",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 31, "w": 12, "h": 7 },
      "fieldConfig": {
        "defaults": { "unit": "none" }
      },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "rate(research_loop_runs_total[10m])", "legendFormat": "Loop runs/min {{status}}" },
        { "expr": "research_priority_score", "legendFormat": "Research Priority" },
        { "expr": "adaptive_efficiency_score", "legendFormat": "Adaptive Efficiency" }
      ]
    },

    {
      "id": 51,
      "title": "Governance Event Counts",
      "type": "stat",
      "gridPos": { "x": 12, "y": 31, "w": 12, "h": 7 },
      "fieldConfig": {
        "defaults": { "unit": "short" }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "targets": [
        { "expr": "increase(autonomous_execution_total[1h])", "legendFormat": "Exec cycles/hr" },
        { "expr": "increase(autonomous_strategy_switch_total[1h])", "legendFormat": "Strategy switches/hr" },
        { "expr": "increase(strategy_retirement_total[1h])", "legendFormat": "Retirements/hr" },
        { "expr": "increase(autonomous_recommendations_total[1h])", "legendFormat": "Recommendations/hr" }
      ]
    }

  ]
}
