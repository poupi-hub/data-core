{
  "title": "Adaptive Policy Contract",
  "uid": "adaptive-policy-v1",
  "version": 1,
  "schemaVersion": 38,
  "refresh": "30s",
  "time": { "from": "now-3h", "to": "now" },
  "tags": ["adaptive-policy", "adaptive-intelligence", "enforcement", "platform"],
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Policy Mode",
      "description": "Current adaptive policy enforcement mode (1=OBSERVE_ONLY … 4=FAIL_CLOSED)",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": {
              "1": { "text": "OBSERVE_ONLY", "color": "green" },
              "2": { "text": "WARN_ONLY",    "color": "blue" },
              "3": { "text": "SAFE_MODE",    "color": "orange" },
              "4": { "text": "FAIL_CLOSED",  "color": "red" }
            }}
          ]
        }
      },
      "targets": [{ "expr": "adaptive_policy_mode", "legendFormat": "Mode" }]
    },
    {
      "id": 2,
      "type": "gauge",
      "title": "Adjusted Confidence Score",
      "description": "Confidence score after calibration + uncertainty penalties (0-100)",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "showThresholdMarkers": true },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0, "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": 0  },
              { "color": "orange", "value": 40 },
              { "color": "yellow", "value": 60 },
              { "color": "green",  "value": 80 }
            ]
          }
        }
      },
      "targets": [{ "expr": "adaptive_policy_confidence_score", "legendFormat": "Confidence" }]
    },
    {
      "id": 3,
      "type": "gauge",
      "title": "Replayability Score",
      "description": "Replayability score from Operational Truth (0-100). Below 60 → BOOST blocked.",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "showThresholdMarkers": true },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0, "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": 0  },
              { "color": "orange", "value": 40 },
              { "color": "yellow", "value": 60 },
              { "color": "green",  "value": 70 }
            ]
          }
        }
      },
      "targets": [{ "expr": "adaptive_policy_replayability_score", "legendFormat": "Replayability" }]
    },
    {
      "id": 4,
      "type": "gauge",
      "title": "Quant Reliability Score",
      "description": "Quant reliability / entropy proxy from Operational Truth (0-100).",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "showThresholdMarkers": true },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0, "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": 0  },
              { "color": "orange", "value": 40 },
              { "color": "yellow", "value": 60 },
              { "color": "green",  "value": 75 }
            ]
          }
        }
      },
      "targets": [{ "expr": "adaptive_policy_quant_reliability_score", "legendFormat": "Quant Reliability" }]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "BOOST Blocked",
      "description": "1 = BOOST recommendation is currently blocked by safety validator",
      "gridPos": { "x": 16, "y": 0, "w": 3, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": {
              "0": { "text": "ALLOWED", "color": "green" },
              "1": { "text": "BLOCKED", "color": "red" }
            }}
          ]
        }
      },
      "targets": [{ "expr": "adaptive_policy_boost_blocked_state", "legendFormat": "BOOST" }]
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Safe Mode",
      "description": "1 = safe_mode active (position sizing hints reduced)",
      "gridPos": { "x": 19, "y": 0, "w": 2, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": {
              "0": { "text": "OFF",    "color": "green" },
              "1": { "text": "ACTIVE", "color": "orange" }
            }}
          ]
        }
      },
      "targets": [{ "expr": "adaptive_policy_safe_mode_state", "legendFormat": "Safe Mode" }]
    },
    {
      "id": 7,
      "type": "stat",
      "title": "Rollout Phase",
      "description": "Current rollout phase (1=OBSERVE_ONLY … 4=FAIL_CLOSED_CRITICAL_ONLY)",
      "gridPos": { "x": 21, "y": 0, "w": 3, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": {
              "1": { "text": "1 — OBSERVE" },
              "2": { "text": "2 — WARN" },
              "3": { "text": "3 — SAFE" },
              "4": { "text": "4 — FAIL_CLOSED" }
            }}
          ]
        }
      },
      "targets": [{ "expr": "adaptive_policy_rollout_phase", "legendFormat": "Phase" }]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "BOOST Blocks Rate",
      "description": "Rate of BOOST blocks by reason class over time",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "options": { "tooltip": { "mode": "multi" } },
      "fieldConfig": {
        "defaults": { "unit": "ops", "custom": { "lineWidth": 2, "fillOpacity": 10 } }
      },
      "targets": [
        { "expr": "sum by (reason_class) (rate(adaptive_policy_boost_blocked_total[5m]))", "legendFormat": "{{reason_class}}" }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Quant / Entropy Penalties",
      "description": "Entropy-driven confidence penalty increments over time",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "options": { "tooltip": { "mode": "multi" } },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 2, "fillOpacity": 10 } }
      },
      "targets": [
        { "expr": "rate(adaptive_policy_entropy_penalty_total[5m])", "legendFormat": "Entropy penalty/s" }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Confidence Penalties Over Time",
      "description": "Total confidence penalty points applied per unit time",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "options": { "tooltip": { "mode": "multi" } },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 2, "fillOpacity": 10 } }
      },
      "targets": [
        {
          "expr": "rate(adaptive_policy_confidence_penalty_total{penalty_type=\"total\"}[5m])",
          "legendFormat": "Confidence penalty/s"
        }
      ]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Safe Mode + Fail Closed Frequency",
      "description": "Cumulative contract generations that triggered safe_mode or fail_closed",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "options": { "tooltip": { "mode": "multi" } },
      "fieldConfig": {
        "defaults": { "unit": "ops", "custom": { "lineWidth": 2, "fillOpacity": 10 } }
      },
      "targets": [
        { "expr": "rate(adaptive_policy_safe_mode_total[5m])",    "legendFormat": "safe_mode/s" },
        { "expr": "rate(adaptive_policy_fail_closed_total[5m])",  "legendFormat": "fail_closed/s" }
      ]
    }
  ]
}
