          "thresholds": {"mode":"absolute","steps":[
            {"color":"red","value":0},{"color":"orange","value":40},
            {"color":"yellow","value":55},{"color":"green","value":75}
          ]},
          "min":0,"max":100,"unit":"short"
        }
      },
      "options": {"reduceOptions":{"calcs":["lastNotNull"]},"orientation":"auto","textMode":"auto","colorMode":"background"},
      "targets": [{"expr":"live_governance_score","legendFormat":"live_governance_score","refId":"A"}]
    },
